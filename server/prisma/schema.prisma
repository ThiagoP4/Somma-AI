generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  idProfile     String         @id @db.Uuid
  first_name    String
  last_name     String
  avatar_url    String?
  updated_at    DateTime       @updatedAt @db.Timestamptz()
  subscriptions Subscription[]

  @@map("usr_profile")
}

// --- MÓDULO FINANCEIRO ---

model Category {
  idCategory  Int        @id @default(autoincrement())
  description String
  color       String
  user_id     String     @db.Uuid
  purchases   Purchase[]
  incomes     Income[]

  @@map("fin_category")
}

model Purchase {
  idPurchase Int      @id @default(autoincrement())
  title      String
  value      Float
  date       DateTime @db.Timestamptz()
  total_installments Int              @default(1)
  categoryId Int
  user_id    String   @db.Uuid

  obsId Int?
  obs   ObservationType? @relation(fields: [obsId], references: [idObservation], onDelete: Cascade)

  category Category @relation(fields: [categoryId], references: [idCategory], onDelete: Cascade)

  installments Installment[]

  @@map("fin_purchase")
}

model Installment {
  idInstallment     Int      @id @default(autoincrement())
  purchaseId        Int      // FK para a compra principal
  installmentNumber Int      // Qual é essa parcela? (ex: 1, 2, 3...)
  value             Float    // Valor desta parcela (ex: 100.00)
  dueDate           DateTime @db.Timestamptz() // Data de vencimento desta parcela
  paid              Boolean  @default(false)     // Controle de pago/pendente
  purchase Purchase @relation(fields: [purchaseId], references: [idPurchase], onDelete: Cascade)
  @@map("fin_installment")
}

model ObservationType {
  idObservation Int    @id @default(autoincrement())
  description   String
  user_id       String @db.Uuid

  purchases Purchase[]
  incomes   Income[]

  @@map("fin_observation_types")
}

model Income {
  idIncome Int      @id @default(autoincrement())
  title    String
  value    Float
  date     DateTime @db.Timestamp()
  user_id  String   @db.Uuid

  categoryId Int?
  obsId      Int?

  category Category?        @relation(fields: [categoryId], references: [idCategory], onDelete: SetNull)
  obs      ObservationType? @relation(fields: [obsId], references: [idObservation], onDelete: SetNull)

  @@map("fin_income")
}

model Subscription {
  idSubscription Int     @id @default(autoincrement())
  plan_name      String
  monthly_price  Float
  active         Boolean @default(true)
  user_id        String  @db.Uuid

  profile Profile @relation(fields: [user_id], references: [idProfile], onDelete: Cascade)

  @@map("opt_subscription")
}
